# OnePortfolio — Environment Configuration Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.


# Flask secret key — used to sign sessions and CSRF tokens.
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Gmail address and App Password used to send verification and reset emails.
# Requires a Gmail App Password (not your regular password).
# Enable at: https://myaccount.google.com/apppasswords  (2FA must be on)
EMAIL_USER=yourapp@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Public base URL of the app — used to build password reset links in emails.
# No trailing slash. Example production value: https://yourapp.pythonanywhere.com
APP_BASE_URL=http://127.0.0.1:5000

# SQLAlchemy database URI — defaults to SQLite if not set.
# Examples:
#   sqlite:///portfolio.db
#   postgresql://user:password@localhost/portfolio
# DATABASE_URL=sqlite:///portfolio.db

# Set to 1 when serving over HTTPS so the session cookie is sent only on secure connections.
# Always 0 in local development, always 1 in production.
SESSION_COOKIE_SECURE=0

# Development only: auto-login as the first user in the database, bypassing authentication.
# Must be 0 (or unset) in production — exposing this in production is a critical security risk.
DEV_AUTO_LOGIN=0
