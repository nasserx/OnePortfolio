# OnePortfolio — Git Ignore Rules


# Python bytecode and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local databases and build artifacts
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.sqlite3-journal
*.sqlite3-shm
*.sqlite3-wal

# Flask instance folder and runtime files
instance/
*.log
logs/
*.pid

# Environment variables — contains secrets, never commit
.env

# OS and editor metadata
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Environment variants
.env.*
!.env.example

# SQLite runtime files
*.db-journal
*.db-shm
*.db-wal

# Generated local artifacts
project-structure.txt
screenshots/
